# =============================================================================
# Variables de entorno — Portal Contabilidad con María
# Copia este archivo a `.env.local` y rellena con los valores de tu proyecto Supabase.
# (Supabase Dashboard → Project Settings → API)
# =============================================================================

# URL del proyecto (ej: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (segura de exponer; la seguridad la impone RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave "service_role" (SECRETA — solo servidor, nunca en el navegador).
# Se usará en Fase 2 para que el admin cree usuarios/clientes.
SUPABASE_SERVICE_ROLE_KEY=
